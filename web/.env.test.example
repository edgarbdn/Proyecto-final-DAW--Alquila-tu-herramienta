# URL base del servidor Next.js que se va a probar
TEST_BASE_URL=http://localhost:3000

# Credenciales de Supabase
# IMPORTANTE: La SERVICE_ROLE_KEY tiene poderes de admin sobre tu BD.
# NUNCA la subas a Git. Está aquí solo para que los tests puedan crear
# y eliminar usuarios de prueba automáticamente.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Usuarios de prueba — los crea el script test:setup
TEST_USER_CLIENTE_EMAIL=test-cliente@example.com
TEST_USER_CLIENTE_PASSWORD=TestPassword123!

TEST_USER_VENDEDOR_EMAIL=test-vendedor@example.com
TEST_USER_VENDEDOR_PASSWORD=TestPassword123!

TEST_USER_ADMIN_EMAIL=test-admin@example.com
TEST_USER_ADMIN_PASSWORD=TestPassword123!
